from openmeteo_requests import Client
from requests_cache import CachedSession
from retry_requests import retry
from requests import get
from os import path
from yaml import safe_load
from json import dumps
from time import sleep
from datetime import datetime, UTC
from argparse import ArgumentParser, Namespace


def get_args() -> Namespace:
    parser = ArgumentParser(
        description="Tool to output Temperature data in json format"
    )
    parser.add_argument(
        "-h",
        "--home",
        action="store_true"
    )
    parser.add_argument(
        "-c",
        "--config",
        type=str,
        default=path.join(
            path.expanduser("~"), ".config", "waybar", "scripts", "haas.yaml"
        )
    )
    return parser.parse_args()

def get_config(config_path) -> dict:
    if not path.exists(config_path):
        raise RuntimeError(
            f"Config path: {config_path} does not exist"
        )
    with open(config_path, "r") as fp:
        data = fp.read()
    # Create try - except when error occurs
    yaml_data = safe_load(data)
    return yaml_data  # config data

def time_formater(seconds: int | str) -> str:
    seconds = int(seconds)
    if seconds > 86400:
        return f"{seconds // 86400}d"
    elif seconds > 3600:
        return f"{seconds // 3600}h {(seconds % 3600) // 60}m"
    elif seconds > 60:
        return f"{seconds // 60}m {seconds % 60}s"
    else:
        return f"{seconds}"


class Widget:
    def __init__(self, args: Namespace) -> None:
        self.args = args
        self.config = get_config(args.config)
        self.token = get_config(self.config["haas"]["token_path"])["token"]
        self.city_lat, self.city_long = self._get_coords()
        self.openmeteo = Client(
            session=retry(
                CachedSession(
                    path.join(path.expanduser("~"), ".cache"),
                    expire_after=3600
                ),
                retries=5,
                backoff_factor=.2
            )
        )
        self.entities = {}
        self.weather = {}
        for entity in self.config["haas"]["entity_ids"]:
            self.entities[entity] = {
                "name": None,
                "state": None,
                "unit": None,
                "last_changed": None,
                "last_updated": None
            }
        if "update_interval" in self.config:
            self.update_interval = self.config["update_interval"]
        else:
            self.update_interval = 5 * 60

    def run(self) -> None:
        while True:
            self.get_entity_states()
            self.get_weather()
            if self.args.home:
                self.print_home_data()
            else:
                self.print_data()
            sleep(self.update_interval)

    def print_home_data(self) -> None:
        entity_text = []
        for entity in self.entities:
            if "office" in entity:
                entity_text.append(
                    f"O: {self.entities[entity]['state']}"
                    f"{self.entities[entity]['unit']}"
                )
            if "wohnzimmer" in entity:
                entity_text.append(
                    f"W: {self.entities[entity]['state']}"
                    f"{self.entities[entity]['unit']}"
                )
        print(
            dumps({
                "text": " ".join(entity_text),
                "tooltip": (
                    f"Temp: {self.weather['temperature_2m']}°C\n"
                    f"Feel: {self.weather['apparent_temperature']}°C\n"
                    f"Humi: {self.weather['humidity_2m']}%"
                )
            }),
            flush=True
        )

    def print_data(self) -> None:
        entity_text = []
        for entity in self.entities:
            entity_text.append(
                f"{self.entities[entity]['name']}\n"
                f"{self.entities[entity]['state']}"
                f"{self.entities[entity]['unit']}\n"
                f"{time_formater(self.entities[entity]['last_updated']} ago"
            )
        print(
            dumps({
                "text": (
                    f"Temp: {self.weather['temperature_2m']}°C"
                    f" Humi: {self.weather['humidity_2m']}%"
                ),
                "tooltip": "\n\n".join(entity_text)
            }),
            flush=True
        )

    def _get_coords(self) -> tuple:
        city = self.config["weather"]["city"]
        response = get(
            "https://geocoding-api.open-meteo.com/v1/search",
            params={"name": city, "count": 1, "format": "json"}
        )
        if (
            response.status_code not in [200, 300, 301]
            or not response.json().get("results")
        ):
            while True:
                print(
                    dumps({
                        "text": f"City {city} was not found"
                    }),
                    flush=True
                )
                sleep(60)
        result = response.json()["results"][0]
        return result["latitude"], result["longitude"]

    def get_weather(self) -> None:
        # Add try except if error occurs
        response = self.openmeteo.weather_api(
            "https://api.open-meteo.com/v1/forecast",
            params={
                "latitude": self.city_lat,
                "longitude": self.city_long,
                "current": [
                    "temperature_2m",
                    "relative_humidity_2m",
                    "apparent_temperature"
                ]
            }
        )
        current = response[0].Current()
        self.weather = {
            "temperature_2m": f"{current.Variables(0).Value():.1f}",
            "humidity_2m": f"{current.Variables(1).Value():.1f}",
            "apparent_temperature": f"{current.Variables(2).Value():.1f}"
        }

    def get_entity_states(self) -> None:
        response = get(
            path.join(self.config["haas"]["url"], "api", "states"),
            headers={
                "Authorization": f"Bearer {self.token}",
                "Content-Type": "application/json"
            }
        )
        if response.status_code not in [200, 300, 301]:
            while True:
                print(
                    dumps({
                        "text": "failed to get entities"
                    }),
                    flush=True
                )
                sleep(60)
        result = {}
        for entity in response.json():
            if entity["entity_id"] not in self.entities:
                continue
            entity_id = entity["entity_id"]
            if not self.entities[entity_id]["name"]:
                self.entities[entity_id]["name"] = \
                    entity["attributes"]["friendly_name"]
            self.entities[entity_id]["state"] = entity["state"]
            self.entities[entity_id]["unit"] = \
                entity["attributes"]["unit_of_measurement"]
            self.entities[entity_id]["last_changed"] = (
                datetime.now(UTC) - datetime.strptime(
                    entity["last_changed"], "%Y-%m-%dT%H:%M:%S.%f%z"
                )
            ).seconds
            self.entities[entity_id]["last_updated"] = (
                datetime.now(UTC) - datetime.strptime(
                    entity["last_updated"], "%Y-%m-%dT%H:%M:%S.%f%z"
                )
            ).seconds


if __name__ == "__main__":
    args = get_args()
    widget = Widget(args)
    widget.run()
